{
  "title": "Digital KYC - Application Health",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(flask_http_request_total[1m])",
          "legendFormat": "{{method}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Latency (95th percentile)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(flask_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pod CPU Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"kyc-flask.*\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pod Memory Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{pod=~\"kyc-flask.*\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
